  <diagram id="diff" name="3. Разница">
    <mxGraphModel dx="1500" dy="1050" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1050">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Glossary -->
        <mxCell id="gloss" value="" style="rounded=1;fillColor=#F5F5F5;strokeColor=#CCCCCC;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="5" y="5" width="1200" height="65" as="geometry" />
        </mxCell>
        <mxCell id="gt" value="Кто есть кто:" style="text;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="12" y="8" width="100" height="14" as="geometry" />
        </mxCell>
        <mxCell id="g1" value="Пользователь — бухгалтер, который редактирует операцию.     Money API — сохраняет саму операцию.&#xa;Providing — пересчитывает зависимые данные: связи документов, статусы счетов, бухгалтерские и налоговые проводки.&#xa;Source-of-truth — основная запись операции (Accounting_PaymentOrder).     Производные данные — налоговые проводки, связи, бухсправки." style="text;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="12" y="24" width="1180" height="42" as="geometry" />
        </mxCell>

        <!-- Headers -->
        <mxCell id="h1" value="Сценарий пользователя" style="text;align=center;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="5" y="78" width="230" height="16" as="geometry" />
        </mxCell>
        <mxCell id="h2" value="Как работает сейчас" style="text;align=center;fontSize=13;fontStyle=1;fontColor=#CC0000;" vertex="1" parent="1">
          <mxGeometry x="250" y="78" width="280" height="16" as="geometry" />
        </mxCell>
        <mxCell id="h3" value="Как будет работать" style="text;align=center;fontSize=13;fontStyle=1;fontColor=#007700;" vertex="1" parent="1">
          <mxGeometry x="550" y="78" width="300" height="16" as="geometry" />
        </mxCell>
        <mxCell id="h4" value="Что увидит пользователь" style="text;align=center;fontSize=13;fontStyle=1;fontColor=#333399;" vertex="1" parent="1">
          <mxGeometry x="870" y="78" width="250" height="16" as="geometry" />
        </mxCell>

        <!-- Row 1 -->
        <mxCell id="s1" value="Пользователь меняет&#xa;СНО в одной операции&#xa;и нажимает «Сохранить»" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=5;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="5" y="100" width="230" height="55" as="geometry" />
        </mxCell>
        <mxCell id="w1" value="Сама операция сохраняется сразу.&#xa;Пересчёт связей, статусов и&#xa;налоговых проводок запускается&#xa;позже, через очередь сообщений." style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="250" y="100" width="280" height="55" as="geometry" />
        </mxCell>
        <mxCell id="n1" value="Операция сохраняется, и сразу&#xa;после этого синхронно пересчиты-&#xa;ваются связи, статусы и проводки.&#xa;Ответ приходит после всего." style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="550" y="100" width="300" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r1" value="После сохранения карточка&#xa;операции и общая таблица&#xa;показывают одно и то же." style="rounded=1;fillColor=#E8E8FF;strokeColor=#6666CC;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="870" y="100" width="250" height="55" as="geometry" />
        </mxCell>

        <!-- Row 2 -->
        <mxCell id="s2" value="Пользователь вручную&#xa;задал налоговые проводки" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=5;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="5" y="168" width="230" height="40" as="geometry" />
        </mxCell>
        <mxCell id="w2" value="Ручные проводки сохраняются&#xa;отдельным асинхронным путём." style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="250" y="168" width="280" height="40" as="geometry" />
        </mxCell>
        <mxCell id="n2" value="Ручные проводки тоже сохраняются&#xa;синхронно в рамках того же запроса." style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="550" y="168" width="300" height="40" as="geometry" />
        </mxCell>
        <mxCell id="r2" value="Ручные проводки видны&#xa;сразу после сохранения." style="rounded=1;fillColor=#E8E8FF;strokeColor=#6666CC;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="870" y="168" width="250" height="40" as="geometry" />
        </mxCell>

        <!-- Row 3 -->
        <mxCell id="s3" value="Пользователь меняет СНО&#xa;сразу у нескольких операций" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=5;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="5" y="222" width="230" height="40" as="geometry" />
        </mxCell>
        <mxCell id="w3" value="Система разбивает задачу по&#xa;операциям и обрабатывает по одной." style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="250" y="222" width="280" height="40" as="geometry" />
        </mxCell>
        <mxCell id="n3" value="Распределение остаётся, но внутри&#xa;каждая операция обрабатывается&#xa;тем же синхронным сценарием." style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="550" y="222" width="300" height="40" as="geometry" />
        </mxCell>
        <mxCell id="r3" value="Логика ручного и массового&#xa;изменения одинаковая." style="rounded=1;fillColor=#E8E8FF;strokeColor=#6666CC;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="870" y="222" width="250" height="40" as="geometry" />
        </mxCell>

        <!-- Row 4 -->
        <mxCell id="s4" value="Пользователь меняет&#xa;резерв у операции" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=5;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="5" y="276" width="230" height="35" as="geometry" />
        </mxCell>
        <mxCell id="w4" value="Резерв обновляется отдельным&#xa;асинхронным сценарием." style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="250" y="276" width="280" height="35" as="geometry" />
        </mxCell>
        <mxCell id="n4" value="Резерв обновляется синхронно&#xa;через новый endpoint." style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="550" y="276" width="300" height="35" as="geometry" />
        </mxCell>
        <mxCell id="r4" value="После сохранения резерв&#xa;уже актуален." style="rounded=1;fillColor=#E8E8FF;strokeColor=#6666CC;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="870" y="276" width="250" height="35" as="geometry" />
        </mxCell>

        <!-- Row 5 -->
        <mxCell id="s5" value="Пользователь сохраняет&#xa;платёж поставщику&#xa;с выбранным СНО" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=5;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="5" y="325" width="230" height="48" as="geometry" />
        </mxCell>
        <mxCell id="w5" value="Поле СНО не проходит через&#xa;backend-цепочку этого сценария.&#xa;SQL-модель поддерживает поле,&#xa;но DTO и мапперы — нет." style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="250" y="325" width="280" height="48" as="geometry" />
        </mxCell>
        <mxCell id="n5" value="Поле СНО будет добавлено&#xa;во все DTO, мапперы и проверки.&#xa;E2e тест по всей цепочке." style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="550" y="325" width="300" height="48" as="geometry" />
        </mxCell>
        <mxCell id="r5" value="СНО не потеряется&#xa;при сохранении." style="rounded=1;fillColor=#E8E8FF;strokeColor=#6666CC;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="870" y="325" width="250" height="48" as="geometry" />
        </mxCell>

        <!-- Row 6 -->
        <mxCell id="s6" value="У операции нет&#xa;явного значения СНО" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=5;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="5" y="387" width="230" height="35" as="geometry" />
        </mxCell>
        <mxCell id="w6" value="Система молча подставляет&#xa;значение по умолчанию." style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="250" y="387" width="280" height="35" as="geometry" />
        </mxCell>
