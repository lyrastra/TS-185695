<script type="text/template" id="CashOrderTemplate">
    <div class="newWave">
        <div class="content">
            <div class="documentForm mdContainer">
                <div class="actions">
                    <div data-mddropdown>
                        <span data-mddropdown-link class="link">Скачать</span>
                        <ul data-mddropdown-list class="mdDropDownList" id="download">
                            <li data-type="2">PDF</li>
                            <li data-type="3">XLS</li>
                        </ul>
                    </div>
                    <br/>
                    <span class="link" id="copyDocument">Копировать</span><br/>
                    <span class="link" id="deleteDocument">Удалить</span>
                </div>
                <div class="generalFields">
                    <form>
                        <div class="bankForm">
                            <div class="mdRow">
                                <div class="mdCol-16">
                                    <div data-control="documentheader"></div>
                                </div>
                            </div>
                            <div class="mdRow fieldRow">
                                <div class="mdCol-21">
                                    <div class="mdCol-5">
                                        <label>Касса</label>
                                        <select data-bind="Cash" style="width: 214px;">
                                            <option></option>
                                        </select>
                                    </div>
                                    <div class="mdCol-5">
                                        <label>Тип платежа</label>
                                        <select data-bind="OperationType" style="width: 214px;">
                                            <option></option>
                                        </select>
                                    </div>
                                    <div class="mdCol-3" data-control="workerType">
                                        <label>Тип договора</label>
                                        <select data-bind="WorkerDocumentType" class="sz-medium">
                                            <option></option>
                                        </select>
                                    </div>
                                    <div class="mdCol-7 hidden" id="additionalField"></div>
                                    <div class="mdCol-3" data-control="zReportNumber">
                                        <label>Z-отчет (БСО)</label>
                                        <input type="text" data-bind="ZReportNumber" placeholder="№" class="x-small"/>
                                    </div>
                                </div>
                            </div>
                            <div data-control="operationFields"></div>
                        </div>
                    </form>
                    <div class="mdRow fieldRow postingControl" data-control="postingsAndTax" style="display: none;" />
                </div>
                <div class="mdRow buttonPanel buttons">
                    <div class="mdDoubleButton saveDocumentButton">
                        <div id="saveDocument" class="mdButton innerText">Сохранить</div>
                        <div data-mddropdown class="mdButton direction">
                            <span data-mddropdown-link class=""></span>
                            <ul data-mddropdown-list class="mdDropDownList" id="saveAndDownload">
                                <li data-type="2">Сохранить и скачать в PDF</li>
                                <li data-type="3">Сохранить и скачать в XLS</li>
                            </ul>
                        </div>
                    </div>
                    <a id="saveAndCreate" class="saveAndCreateLink">Сохранить и новый</a>
                    <a id="cancelLink">Отменить</a>
                </div>
            </div>
        </div>
    </div>
</script>

