<script type="text/template" id="TablePaginatorTemplate">
    <aside
            class="paginator">
        <div class="cell">
            <div class="c_guides">
                <!-- PREVIOUS BUTTON -->
                <% if (page > firstPage) { %>
                <a class="serverprevious">
                    <i></i>предыдущая
                </a>
                <% }else{ %>
                <a class="serverprevious disabled">
                    <i></i>предыдущая
                </a>
                <% } %>

                <!-- NEXT BUTTON -->
                <% if (page < totalPages) { %>
                <a class="servernext">следующая<i></i></a>
                <% }else{ %>
                <a class="servernext disabled">
                    следующая<i></i>
                </a>
                <% } %>
            </div>
            <!-- PAGE COUNTER -->
            <!-- p < page+3 && p > page-3 || || p > totalPages-2 -->
            <% if(totalPages > 1){ %>
            <% for(p=1;p<=totalPages;p++){%>
            <% if((page < 5 && p <= 8) || (page > totalPages-3 && p >= totalPages-6)) { %>

            <% if (page == p) { %>
            <% if(page == 1) {%>
            <span class="page selected first"><%= p %></span>
            <% } else {%>
            <span class="page selected"><%= p %></span>
            <% } %>
            <% } else{ %>
            <a class="page"><%= p %></a>
            <% } %>

            <% } else { %>
            <% if(p < page+4 && p > page-4) { %>
            <% if (page == p) { %>
            <% if(page == 1) {%>
            <span class="page selected first"><%= p %></span>
            <% } else {%>
            <span class="page selected"><%= p %></span>
            <% } %>
            <% } else{ %>
            <a class="page"><%= p %></a>
            <% } %>
            <% } %>
            <% } %>
            <%}%>

            <%} %>
        </div>

        <div class="serverhowmany">
            Показывать: <span class="custom-select">
            <% if(totalCount <= 20){ %>
            <% }else if(totalCount <= 50){ %>
            <select name="countSelector" class="countSelector">
                <option
                <% if (perPage == 20) { %> selected="selected" <% } %> value="20">20</option>
                <option
                <% if (perPage == 1000000) { %> selected="selected" <% } %> value="1000000">Все</option>
            </select>
            <span class="custom-select__value"></span>
            <span class="custom-select__button"></span>
            <% } else if(totalCount <= 100) { %>
            <select name="serverhowmany" class="countSelector">
                <option
                <% if (perPage == 20) { %> selected="selected"<% } %> value="20">20</option>
                <option
                <% if (perPage == 50) { %> selected="selected"<% } %> value="50">50</option>
                <option
                <% if (perPage > 50) { %> selected="selected" <% } %> value="1000000">Все</option>
            </select>
            <span class="custom-select__value"></span>
            <span class="custom-select__button"></span>
            <% }else if(totalCount > 100 &&  totalCount <= 300){ %>
            <select name="serverhowmany" class="countSelector">
                <option
                <% if (perPage == 20) { %> selected="selected"<% } %> value="20">20</option>
                <option
                <% if (perPage == 50) { %> selected="selected"<% } %> value="50">50</option>
                <option
                <% if (perPage == 100) { %> selected="selected" <% } %> value="100">100</option>
                <option
                <% if (perPage == 300) { %> selected="selected"<% } %> value="300">Все</option>
            </select>
            <span class="custom-select__value"></span>
            <span class="custom-select__button"></span>
            <% }else if(totalCount > 300){ %>
            <select name="serverhowmany" class="countSelector">
                <option
                <% if (perPage == 20) { %> selected="selected"<% } %> value="20">20</option>
                <option
                <% if (perPage == 50) { %> selected="selected" <% } %> value="50">50</option>
                <option
                <% if (perPage == 100) { %> selected="selected"<% } %> value="100">100</option>
                <option
                <% if (perPage >= 300) { %> selected="selected"<% } %> value="300">300</option>
            </select>
            <span class="custom-select__value"></span>
            <span class="custom-select__button"></span>
            <% } %>

        </span>
        </div>
    </aside></script>


